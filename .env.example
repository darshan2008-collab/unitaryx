# Fresh setup template for Docker/Portainer
# IMPORTANT:
# - Keep POSTGRES_PASSWORD unchanged after first init unless you also ALTER USER in Postgres.
# - Do not set PORT manually in Portainer; compose uses APP_PORT.
# - Set DATABASE_URL only if you want to override DB_HOST/DB_PORT-based connection building.

# Runtime
TZ=Asia/Kolkata
APP_PORT=10184
DATA_ROOT=C:\project data\unitaryx_data
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120

# Flask app
DEBUG=False
SECRET_KEY=replace_with_a_long_random_secret
ADMIN_EMAIL=admin@unitaryx.com
ADMIN_PASS=replace_with_a_strong_admin_password
SUPERADMIN_EMAIL=harikavi1301@gmail.com
SUPERADMIN_PASSWORD=hari@123
SUPERADMIN_NAME=Super Admin

# Database
# Default behavior uses the internal db service in this stack (DB_HOST=db).
# To use an external Postgres, set DB_HOST/DB_PORT (or DATABASE_URL) in Portainer and redeploy.
# External same host Postgres usually: DB_HOST=host.docker.internal
# External remote Postgres: DB_HOST=<remote-ip-or-dns>
POSTGRES_DB=unitaryx
POSTGRES_USER=unitaryx
POSTGRES_PASSWORD=replace_with_a_strong_db_password
DB_HOST=db
DB_PORT=5432
DATABASE_URL=
POSTGRES_PORT=5433

# Google OAuth
GOOGLE_CLIENT_ID=replace_with_google_web_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
GOOGLE_ALLOWED_ORIGINS=https://unitaryx.org,http://localhost:10184,http://127.0.0.1:10184

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=mailbox@example.com
SMTP_PASS=replace_with_smtp_app_password
SMTP_FROM=mailbox@example.com
SMTP_USE_TLS=True
SMTP_USE_SSL=False

# Reverse proxy (optional)
TRAEFIK_ENABLE=false
TRAEFIK_HOST=unitaryx.example.com
