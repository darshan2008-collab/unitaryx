# Runtime
TZ=Asia/Kolkata
APP_PORT=10003
DATA_ROOT=/mnt/Hdd/Hari/Projects/UnitaryX
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120

# Flask app
DEBUG=False
SECRET_KEY=change_this_to_a_long_random_value
ADMIN_EMAIL=admin@unitaryx.com
ADMIN_PASS=change_this_admin_password

# App database (used by app service)
POSTGRES_DB=unitaryx
POSTGRES_USER=unitaryx
POSTGRES_PASSWORD=change_this_strong_db_password
POSTGRES_PORT=5432

# OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_ALLOWED_ORIGINS=https://unitaryx.org

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=mailbox@example.com
SMTP_PASS=your_app_password
SMTP_FROM=mailbox@example.com
SMTP_USE_TLS=True
SMTP_USE_SSL=False

# Traefik (optional)
TRAEFIK_ENABLE=false
TRAEFIK_HOST=unitaryx.example.com
